# DanmuAI environment variable reference (template only)
#
# The desktop app does NOT load .env automatically.
# Settings are stored in %APPDATA%/DanmuAI/config.db via the Web console.
# For scripted runs, load these in your own launcher if needed.

# --- Optional debug / tuning (see README.md) ---
# DANMU_WEB_LAUNCH=browser
# DANMU_DEDUP_PROFILE=1
# DANMU_IMAGE_METRICS=1
# DANMU_API_SCHEDULE_DEBUG=1
# DANMU_MIN_API_INTERVAL_MS=800

# --- Supabase (backend GET /api/update/channels + frontend announcements/feedback) ---
# Prefer web/static/supabase-config.js for desktop builds; env vars override when set.
# DANMU_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# DANMU_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# --- Example API fields (not read by main.py without custom loader) ---
DANMU_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
DANMU_API_KEY=your_api_key_here
DANMU_MODEL=doubao-seed-1-6-flash-250828
DANMU_API_MODE=doubao
DANMU_CAPTURE_REGION_X=0
DANMU_CAPTURE_REGION_Y=0
DANMU_CAPTURE_REGION_W=400
DANMU_CAPTURE_REGION_H=300
